# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_SECRET_KEY=change-this-in-production

# Mergado OAuth Configuration
# Redirect URI must match the app URL and Mergado app settings exactly.
# No Docker: http://localhost:5000/auth/callback
# With Docker (app on 5001): http://localhost:5001/auth/callback
MERGADO_CLIENT_ID=your_mergado_client_id
MERGADO_CLIENT_SECRET=your_mergado_client_secret
MERGADO_REDIRECT_URI=http://localhost:5000/auth/callback

# Database Configuration
# Development (SQLite for quick local dev)
DATABASE_URL=sqlite:///mergado_app.db
# Production (PostgreSQL recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/shopify_connector

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text

# Server Configuration
HOST=0.0.0.0
PORT=5000
